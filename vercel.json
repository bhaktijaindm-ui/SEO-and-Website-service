{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/seo-service", "destination": "/" },
    { "source": "/seo-service/services", "destination": "/services" },
    { "source": "/seo-service/casestudies", "destination": "/case-studies" },
    { "source": "/seo-service/aboutus", "destination": "/about" },
    { "source": "/seo-service/pricing", "destination": "/pricing" },
    { "source": "/seo-service/blog", "destination": "/blog" },
    { "source": "/seo-service/contact", "destination": "/contact" },
    { "source": "/seo-service/testimonials", "destination": "/testimonials" },
    { "source": "/seo-service/case-:slug", "destination": "/case-:slug" },
    { "source": "/seo-service/:slug*", "destination": "/:slug*" },
    { "source": "/web-design-service", "destination": "/" },
    { "source": "/web-design-service/services", "destination": "/services" },
    { "source": "/web-design-service/casestudies", "destination": "/case-studies" },
    { "source": "/web-design-service/aboutus", "destination": "/about" },
    { "source": "/web-design-service/pricing", "destination": "/pricing" },
    { "source": "/web-design-service/blog", "destination": "/blog" },
    { "source": "/web-design-service/contact", "destination": "/contact" },
    { "source": "/web-design-service/testimonials", "destination": "/testimonials" },
    { "source": "/web-design-service/case-:slug", "destination": "/case-:slug" },
    { "source": "/web-design-service/:slug*", "destination": "/:slug*" }
  ]
}
